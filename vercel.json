{
  "version": 2,
  "builds": [
    {
      "src": "api/webhook.ts",
      "use": "@vercel/node",
      "config": { "maxDuration": 60 }
    },
    {
      "src": "api/weekly-report.ts",
      "use": "@vercel/node",
      "config": { "maxDuration": 30 }
    },
    {
      "src": "api/privacy.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/send-prospects.ts",
      "use": "@vercel/node",
      "config": { "maxDuration": 60 }
    }
  ],
  "routes": [
    { "src": "/api/webhook", "dest": "/api/webhook.ts" },
    { "src": "/api/weekly-report", "dest": "/api/weekly-report.ts" },
    { "src": "/api/privacy", "dest": "/api/privacy.ts" },
    { "src": "/api/send-prospects", "dest": "/api/send-prospects.ts" }
  ],
  "crons": [
    {
      "path": "/api/weekly-report",
      "schedule": "0 11 * * 1"
    }
  ]
}
