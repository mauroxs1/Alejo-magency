{
  "version": 2,
  "builds": [
    {
      "src": "api/*.ts",
      "use": "@vercel/node"
    }
  ],
  "functions": {
    "api/webhook.ts": {
      "maxDuration": 90
    }
  },
  "routes": [
    {
      "src": "/api/webhook",
      "dest": "/api/webhook.ts"
    },
    {
      "src": "/api/privacy",
      "dest": "/api/privacy.ts"
    }
  ]
}
