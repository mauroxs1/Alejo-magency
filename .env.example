# Meta / WhatsApp Cloud API
META_ACCESS_TOKEN=           # System User Permanent Access Token de Meta
PHONE_NUMBER_ID=             # ID del número de teléfono (Meta for Developers > Configuración API)
WABA_ID=                     # WhatsApp Business Account ID
WEBHOOK_VERIFY_TOKEN=        # Token que vos elegís para verificar el webhook (ej: alejo_magency_2024)

# Anthropic
ANTHROPIC_API_KEY=           # sk-ant-...

# Google Sheets Web App
SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/AKfycbzegWJXwf6X2foK0CLEi8Gjn426XDCbo-07hP6DYQRkJjqzZm1K8l4Bqk80FRkqnjAi/exec

# Notificaciones de cierre de venta (formato internacional sin +, ej: 5492614001234)
MAURO_PHONE=                 # Número WhatsApp de Mauro
ROBERTO_PHONE=               # Número WhatsApp de Roberto

# Kit Live Commerce
KIT_LANDING_URL=             # URL final de la landing de venta del Kit Live Commerce
